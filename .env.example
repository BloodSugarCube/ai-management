APP_NAME="AI-management"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# --- AI-management ---
ADMIN_USERNAME=admin
# Рекомендуется ADMIN_PASSWORD_HASH (см. php artisan admin:hash-password)
ADMIN_PASSWORD_HASH=
# Только для локальной разработки (небезопасно в проде):
ADMIN_PASSWORD=

REDMINE_BASE_URL=https://redmine.example.com
REDMINE_API_KEY=
# false — только для локальной разработки при cURL error 60 (Windows без актуального CA)
REDMINE_VERIFY_SSL=true
# REDMINE_CA_BUNDLE=C:/Server/bin/PHP/8.3.12/extras/ssl/cacert.pem
REDMINE_HTTP_TIMEOUT=60
REDMINE_PAGE_SIZE=100
# open | * (все статусы — осторожно, может быть тяжело)
REDMINE_ISSUE_STATUS_FILTER=open
# Имена статусов «в работе» в Redmine (через |), для списка задач сотрудника
REDMINE_IN_PROGRESS_STATUS_NAMES="In progress|В работе|Started"

GENAPI_BASE_URL=https://api.gen-api.ru
GENAPI_API_KEY=
GENAPI_HTTP_TIMEOUT=120
GENAPI_VERIFY_SSL=true
GENAPI_STEP1_NETWORK_ID=
GENAPI_STEP2_NETWORK_ID=
GENAPI_IS_ASYNC=false
# Дополнительные поля JSON-тела запроса GenAPI (строка JSON), например: {"temperature":0.2}
# Тело по умолчанию: is_sync + messages[{role,user,content}]
GENAPI_EXTRA_JSON_BODY=
